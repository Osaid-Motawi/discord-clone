# Copy to .env.local and fill in after running `npx convex dev`.
# .env.local is gitignored and must never be committed.

# Convex deployment URL (printed by `npx convex dev`)
VITE_CONVEX_URL=

# Set on the Convex deployment (not here) via `npx convex env set`:
#   JWT_PRIVATE_KEY, JWKS, SITE_URL   (generated by `npx @convex-dev/auth`)
